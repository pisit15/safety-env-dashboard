# Google Sheets API — Service Account JSON (paste the entire JSON as one line)
# Get this from: Google Cloud Console → APIs & Services → Credentials → Service Account → Keys → Add Key → JSON
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"safety-dashboard@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# If not set, dashboard will use demo data automatically
